# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# CORS Origins - Comma-separated list of allowed domains
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# API Keys - Get your key from https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace (optional fallback)
HF_TOKEN=your_huggingface_token_here
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:novita
HF_BASE_URL=https://router.huggingface.co/v1

# Email Configuration - For sending evaluations and reports
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
CALENDLY_LINK=https://calendly.com/your-company/interview

# Directory Configurations
OUTPUT_DIR=output
REPORT_DIR=results
